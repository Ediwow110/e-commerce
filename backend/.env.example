# =============================================================================
# LUXE Commerce API — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# =============================================================================

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────────────
# Generate a strong password for production and use managed Postgres (e.g. Supabase, Neon, RDS)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/luxe_commerce?schema=public"

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ACCESS and REFRESH MUST be different values
JWT_ACCESS_SECRET=replace-with-64-char-random-hex
JWT_REFRESH_SECRET=replace-with-a-different-64-char-random-hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# ─── Seeding (development only) ──────────────────────────────────────────────
SEED_SUPER_ADMIN_EMAIL=owner@luxe.test
SEED_SUPER_ADMIN_PASSWORD=
SEED_CUSTOMER_PASSWORD=password123

# =============================================================================
# PAYMENT PROVIDER CONFIGURATION
# =============================================================================
# Supported providers: paymongo | maya | xendit | manual | mock
# In PRODUCTION: mock is NOT allowed. You MUST configure a real provider.
# =============================================================================

# Default payment provider for checkout
PAYMENT_PROVIDER_DEFAULT=mock

# --- Webhook Security ---
# REQUIRED in production. Used to verify incoming webhook signatures.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_WEBHOOK_SECRET=whsec_replace_with_random_secret

# --- PayMongo (Philippines) ---
# Docs: https://developers.paymongo.com
# Webhook URL to register: https://your-api.com/api/payments/webhook/paymongo
PAYMONGO_PUBLIC_KEY=pk_test_
PAYMONGO_SECRET_KEY=sk_test_

# --- Maya / PayMaya (Philippines) ---
# Docs: https://developers.maya.ph
# Webhook URL to register: https://your-api.com/api/payments/webhook/maya
MAYA_PUBLIC_KEY=pk-
MAYA_SECRET_KEY=sk-

# --- Xendit (Southeast Asia) ---
# Docs: https://developers.xendit.co
# Webhook URL to register: https://your-api.com/api/payments/webhook/xendit
XENDIT_SECRET_KEY=xnd_

# =============================================================================
# MAIL CONFIGURATION
# =============================================================================

# Provider: mock | resend | sendgrid | mailgun
# mock — logs emails to console only; no real emails sent
MAIL_PROVIDER=mock
MAIL_FROM="LUXE Jewelry & Bags <orders@yourdomain.com>"
MAIL_REPLY_TO=support@yourdomain.com

# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# SendGrid — https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# Mailgun — https://app.mailgun.com/settings/api_security
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# =============================================================================
# GOOGLE OAUTH (optional)
# =============================================================================
# Required only for Google Sign-In on the customer storefront
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
