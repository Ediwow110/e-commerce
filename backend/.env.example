NODE_ENV=development
PORT=8080
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8080
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/luxe_commerce?schema=public"
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
SEED_SUPER_ADMIN_EMAIL=owner@luxe.test
SEED_SUPER_ADMIN_PASSWORD=
SEED_CUSTOMER_PASSWORD=password123

# =============================================================================
# PAYMENT PROVIDER CONFIGURATION
# =============================================================================
# Supported providers: paymongo | maya | xendit | manual | mock
# In PRODUCTION: mock is NOT allowed. You MUST configure a real provider.
# =============================================================================

# Default payment provider for checkout
PAYMENT_PROVIDER_DEFAULT=mock

# --- PayMongo (Philippines) ---
# Get keys from: https://dashboard.paymongo.com
# Webhook URL: https://your-api.com/api/payments/webhook/paymongo
PAYMONGO_PUBLIC_KEY=pk_test_...
PAYMONGO_SECRET_KEY=sk_test_...

# --- Maya (Philippines) ---
# Get keys from: https://developers.maya.ph
# Webhook URL: https://your-api.com/api/payments/webhook/maya
MAYA_PUBLIC_KEY=pk-...
MAYA_SECRET_KEY=sk-...

# --- Xendit (Southeast Asia) ---
# Get keys from: https://dashboard.xendit.co
# Webhook URL: https://your-api.com/api/payments/webhook/xendit
XENDIT_SECRET_KEY=xnd_...

# --- Webhook Security ---
# REQUIRED in production. Used to verify webhook signatures.
# Generate a strong random string: openssl rand -hex 32
PAYMENT_WEBHOOK_SECRET=whsec_...

# API mail provider: resend | sendgrid | mailgun | mock
MAIL_PROVIDER=mock
MAIL_FROM="LUXE Jewelry & Bags <orders@yourdomain.com>"
MAIL_REPLY_TO=support@yourdomain.com
RESEND_API_KEY=
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
