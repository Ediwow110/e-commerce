# =============================================================================
# LUXE Commerce API — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# =============================================================================

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────────────
# Use managed Postgres in production (Supabase, Neon, RDS). Add ?sslmode=require for prod.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/luxe_commerce?schema=public"

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ACCESS and REFRESH MUST be different values.
JWT_ACCESS_SECRET=replace-with-64-char-random-hex
JWT_REFRESH_SECRET=replace-with-a-different-64-char-random-hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. Must NOT contain localhost in production.
CORS_ORIGIN=http://localhost:5173

# ─── Seeding (NEVER set these in production) ─────────────────────────────────
# Leaving these blank will skip creating demo users. Seed will refuse to run when
# NODE_ENV=production unless ALLOW_PROD_SEED=1 is also set.
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
SEED_CUSTOMER_EMAIL=
SEED_CUSTOMER_PASSWORD=

# =============================================================================
# PAYMENT PROVIDER CONFIGURATION
# =============================================================================
# Supported providers: paymongo | maya | xendit | manual | mock
# In PRODUCTION: mock is REJECTED. Configure a real provider.
# =============================================================================

PAYMENT_PROVIDER_DEFAULT=mock

# --- Webhook Security (REQUIRED in production) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYMENT_WEBHOOK_SECRET=

# --- PayMongo (Philippines) ---
# Header: Paymongo-Signature; HMAC-SHA256 of "<t>.<rawBody>" with PAYMENT_WEBHOOK_SECRET.
PAYMONGO_PUBLIC_KEY=
PAYMONGO_SECRET_KEY=

# --- Maya / PayMaya (Philippines) ---
# Webhooks authenticate via Basic Auth header configured on dashboard.
# Set MAYA_WEBHOOK_AUTH to the exact "Basic <base64>" string Maya will send.
MAYA_PUBLIC_KEY=
MAYA_SECRET_KEY=
MAYA_WEBHOOK_AUTH=

# --- Xendit (Southeast Asia) ---
# Header: x-callback-token; static token configured on dashboard.
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=

# =============================================================================
# MAIL CONFIGURATION
# =============================================================================
# Provider: mock | resend | sendgrid | mailgun
MAIL_PROVIDER=mock
MAIL_FROM="LUXE Jewelry & Bags <orders@yourdomain.com>"
MAIL_REPLY_TO=support@yourdomain.com

RESEND_API_KEY=
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# =============================================================================
# GOOGLE OAUTH (optional, customer login only)
# =============================================================================
GOOGLE_CLIENT_ID=
